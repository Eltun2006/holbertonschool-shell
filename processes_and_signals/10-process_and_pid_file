#!/usr/bin/env bash
# This script creates a PID file and handles signals
mkdir -p /var/run 2>/dev/null
echo $$ > /var/run/myscript.pid 2>/dev/null || echo $$ > /tmp/myscript.pid

clean_up() {
    rm -f /var/run/myscript.pid /tmp/myscript.pid
    exit
}

trap "echo 'I hate the kill command'; clean_up" SIGTERM
trap "echo 'Y U no love me?!'" SIGINT
trap "clean_up" SIGQUIT

while true
do
    echo "To infinity and beyond"
    sleep 2
done
